# Meilisearch Cloud 接続設定
# Meilisearch CloudのダッシュボードからホストURLとAPIキーを取得してください
# https://cloud.meilisearch.com/

# MeilisearchホストURL（例: https://ms-xxxxx.meilisearch.io）
MEILISEARCH_HOST=

# 管理用APIキー（インデックス作成・データ投入に使用）
MEILISEARCH_ADMIN_API_KEY=

# 検索用APIキー（フロントエンドでの検索に使用、読み取り専用）
MEILISEARCH_SEARCH_API_KEY=
