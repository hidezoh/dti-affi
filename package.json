{
  "name": "dti-affi",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "npm run build:css && wrangler deploy --dry-run",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/static/styles.css --minify",
    "deploy": "npm run build:css && wrangler deploy",
    "lint": "oxlint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "meilisearch:setup": "tsx scripts/setup-meilisearch.ts",
    "meilisearch:sync": "tsx scripts/sync-to-meilisearch.ts"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "meilisearch": "^0.55.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@cloudflare/workers-types": "^4.20250306.0",
    "@tailwindcss/cli": "^4",
    "@types/adm-zip": "^0.5.3",
    "@types/node": "^20",
    "adm-zip": "^0.5.10",
    "axios": "^1.6.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "oxlint": "^1",
    "sharp": "^0.33.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "undici": "^7.22.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.0.0"
  }
}
