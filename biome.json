{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": false
  },
  "files": {
    "ignore": [
      "dist/**",
      "node_modules/**",
      ".wrangler/**",
      "public/**",
      "scripts/**",
      ".claude/**",
      "data/**"
    ]
  }
}
